# Runtime
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Contact provider strategy: noop | webhook | resend
CONTACT_PROVIDER=noop

# CONTACT_PROVIDER=webhook
# - Required
CONTACT_WEBHOOK_URL=
# - Optional
CONTACT_API_KEY=

# CONTACT_PROVIDER=resend
# - Required
RESEND_API_KEY=
CONTACT_TO_EMAIL= # required for resend, optional for webhook
CONTACT_FROM_EMAIL=
